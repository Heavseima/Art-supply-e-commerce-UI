# Backend API origin + version prefix.
#
# Two states (resolved in src/utils/apiClient.ts):
#   - STATIC (default): leave this UNSET, empty, or set to "none". The
#     storefront serves the canned catalog from src/utils/staticData.ts and
#     never contacts a backend.
#   - LIVE: set this to a valid absolute URL. The data engines use their real
#     fetch() paths against that origin. Restart the dev server after changing
#     (NEXT_PUBLIC_* values are inlined at build time).
#
# NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_API_URL=none
